# n8n Local Environment Configuration
# Generated by: nac init
# Copy this file to .env.local and fill in the values.

# ---- Encryption ----
# IMPORTANT: Use a strong, unique key. This encrypts credential data in the DB.
N8N_ENCRYPTION_KEY=change-me-to-a-strong-random-key

# Optional: comma-separated list of old keys for re-encryption migration
# N8N_ENCRYPTION_KEY_LIST=old_key_1,old_key_2

# ---- n8n ----
N8N_HOST=localhost
N8N_PORT=5678
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# ---- Postgres ----
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# ---- Redis ----
REDIS_USER=default
REDIS_PASSWORD=local_redis_password

# ---- n8n API (for nac api commands) ----
# Generate in n8n UI: Settings > API
# N8N_API_KEY=your-api-key-here

# =============================================================================
# Credential environment variables
# =============================================================================
# These are used by `nac import credentials` to build credential data.
# Set the values for each credential your workflows use.

# OpenAI
# OPENAI_ACCOUNT_API_KEY=sk-...

# OpenRouter
# OPENROUTER_ACCOUNT_API_KEY=sk-or-...

# Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# YouTube OAuth2
# YOUTUBE_ACCOUNT_CLIENT_ID=...
# YOUTUBE_ACCOUNT_CLIENT_SECRET=...
# YOUTUBE_ACCOUNT_REFRESH_TOKEN=...

# Webhook auth (shared secret between Supabase edge functions and n8n)
# N8N_WEBHOOK_AUTH=your-shared-secret

# Supadata
# SUPADATA_API_KEY=...

# Whapi (WhatsApp)
# WHAPI_API_TOKEN=...

# AssemblyAI
# ASSEMBLY_AI_API_KEY=...
