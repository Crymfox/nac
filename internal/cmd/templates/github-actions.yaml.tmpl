name: Deploy n8n
# Generated by: nac ci generate

on:
  push:
    branches: [develop, main]
    paths:
      - "n8n_workflows/**/workflow.json"
      - "n8n_credentials/**/credential.json"

jobs:
  deploy:
    runs-on: ubuntu-latest
    environment: {{ "{{" }} github.ref_name == 'main' && 'production' || 'develop' {{ "}}" }}
    if: github.event_name != 'pull_request' || github.event.pull_request.head.repo.fork == false
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "1.22"

      - name: Install nac
        run: go install github.com/crymfox/nac/cmd/nac@latest

      - name: Backup remote DB tables
        env:
          DB_POSTGRESDB_HOST: {{ "{{" }} secrets.PG_HOST {{ "}}" }}
          DB_POSTGRESDB_PORT: {{ "{{" }} secrets.PG_PORT {{ "}}" }}
          DB_POSTGRESDB_DATABASE: {{ "{{" }} secrets.PG_DB {{ "}}" }}
          DB_POSTGRESDB_USER: {{ "{{" }} secrets.PG_USER {{ "}}" }}
          DB_POSTGRESDB_PASSWORD: {{ "{{" }} secrets.PG_PASSWORD {{ "}}" }}
        run: |
          set -euo pipefail
          mkdir -p backups
          TS=$(date -u +"%Y%m%dT%H%M%SZ")
          OUT="backups/n8n_backup_${TS}.sql"
          docker run --rm \
            -e PGPASSWORD="$DB_POSTGRESDB_PASSWORD" \
            -e PGSSLMODE=require \
            -v "$PWD:/data" postgres:16-alpine \
            pg_dump \
              -h "$DB_POSTGRESDB_HOST" \
              -p "$DB_POSTGRESDB_PORT" \
              -U "$DB_POSTGRESDB_USER" \
              -d "$DB_POSTGRESDB_DATABASE" \
              --no-owner --no-privileges --format=plain \
              --table=public.workflow_entity \
              --table=public.credentials_entity \
              --file="/data/${OUT}"

      - name: Upload DB backup artifact
        uses: actions/upload-artifact@v4
        with:
          name: n8n-db-backup-{{ "{{" }} github.run_id {{ "}}" }}-{{ "{{" }} github.run_attempt {{ "}}" }}
          path: backups/*.sql
          retention-days: 14

      - name: Import workflows
        env:
          DB_POSTGRESDB_HOST: {{ "{{" }} secrets.PG_HOST {{ "}}" }}
          DB_POSTGRESDB_PORT: {{ "{{" }} secrets.PG_PORT {{ "}}" }}
          DB_POSTGRESDB_DATABASE: {{ "{{" }} secrets.PG_DB {{ "}}" }}
          DB_POSTGRESDB_USER: {{ "{{" }} secrets.PG_USER {{ "}}" }}
          DB_POSTGRESDB_PASSWORD: {{ "{{" }} secrets.PG_PASSWORD {{ "}}" }}
          N8N_ENCRYPTION_KEY: {{ "{{" }} secrets.N8N_ENCRYPTION_KEY {{ "}}" }}
        run: |
          ENV_NAME={{ "{{" }} github.ref_name == 'main' && 'production' || 'dev' {{ "}}" }}
          nac import workflows --env "$ENV_NAME"

      - name: Import credentials
        if: always()
        env:
          DB_POSTGRESDB_HOST: {{ "{{" }} secrets.PG_HOST {{ "}}" }}
          DB_POSTGRESDB_PORT: {{ "{{" }} secrets.PG_PORT {{ "}}" }}
          DB_POSTGRESDB_DATABASE: {{ "{{" }} secrets.PG_DB {{ "}}" }}
          DB_POSTGRESDB_USER: {{ "{{" }} secrets.PG_USER {{ "}}" }}
          DB_POSTGRESDB_PASSWORD: {{ "{{" }} secrets.PG_PASSWORD {{ "}}" }}
          N8N_ENCRYPTION_KEY: {{ "{{" }} secrets.N8N_ENCRYPTION_KEY {{ "}}" }}
          N8N_ENCRYPTION_KEY_LIST: {{ "{{" }} secrets.N8N_ENCRYPTION_KEY_LIST {{ "}}" }}
          SUPABASE_URL: {{ "{{" }} secrets.SUPABASE_URL {{ "}}" }}
          SUPABASE_SERVICE_ROLE_KEY: {{ "{{" }} secrets.SUPABASE_SERVICE_ROLE_KEY {{ "}}" }}
        run: |
          ENV_NAME={{ "{{" }} github.ref_name == 'main' && 'production' || 'dev' {{ "}}" }}
          nac import credentials --env "$ENV_NAME"
